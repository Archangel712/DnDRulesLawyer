<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/colorBackground"
    android:clipToPadding="false"
    android:padding="@dimen/screen_padding"
    tools:context=".MainActivity">

    <FrameLayout
        android:id="@+id/searchResultsContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginBottom="12dp"
        app:layout_constraintBottom_toTopOf="@id/searchFiltersScroll"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/secondaryFiltersContainer">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/searchResultsRecyclerView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            tools:listitem="@layout/item_rule_resource" />

        <include
            android:id="@+id/searchLoadingIndicator"
            layout="@layout/view_loading_indicator"
            android:visibility="gone" />

        <TextView
            android:id="@+id/searchEmptyMessageText"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="@string/search_no_results"
            android:textAlignment="center"
            android:textAppearance="?attr/textAppearanceBodyLarge"
            android:visibility="gone" />

    </FrameLayout>

    <LinearLayout
        android:id="@+id/secondaryFiltersContainer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:visibility="visible">

        <HorizontalScrollView
            android:id="@+id/secondaryFiltersScroll"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none">

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/secondaryFilterChipGroup"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:chipSpacingHorizontal="8dp"
                app:singleLine="true"
                app:singleSelection="true"
                tools:visibility="gone" />

        </HorizontalScrollView>

        <LinearLayout
            android:id="@+id/monsterChallengeRatingContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            tools:visibility="visible">

            <TextView
                android:id="@+id/monsterChallengeRatingLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/filter_monster_cr_range"
                android:textAppearance="?attr/textAppearanceBodyMedium" />

            <com.google.android.material.slider.RangeSlider
                android:id="@+id/monsterChallengeRatingSlider"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:stepSize="1"
                android:valueFrom="0"
                android:valueTo="1"
                app:values="@array/filter_monster_cr_default_slider_values" />

        </LinearLayout>

    </LinearLayout>

    <HorizontalScrollView
        android:id="@+id/searchFiltersScroll"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:scrollbars="none"
        app:layout_constraintBottom_toTopOf="@id/searchControlsContainer"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/searchFilterChipGroup"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:chipSpacingHorizontal="8dp"
            app:singleLine="true"
            app:singleSelection="true" />

    </HorizontalScrollView>

    <LinearLayout
        android:id="@+id/searchControlsContainer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <EditText
            android:id="@+id/queryInput"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:hint="@string/search_hint"
            android:imeOptions="actionSearch"
            android:importantForAutofill="no"
            android:inputType="textCapSentences"
            android:singleLine="true" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/voiceButton"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_marginStart="8dp"
            android:contentDescription="@string/voice_input"
            android:insetLeft="0dp"
            android:insetTop="0dp"
            android:insetRight="0dp"
            android:insetBottom="0dp"
            app:cornerRadius="28dp"
            app:icon="@drawable/ic_mic_24"
            app:iconGravity="textStart"
            app:iconPadding="0dp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
